---
import Layout from "@/layouts/main.astro"
import { TooltipShowcase } from "@/components/TooltipShowcase"
---

<Layout title="Tooltip — Interfero Design System">
  <div class="p-6 space-y-6">
    <div>
      <h1 class="text-2xl font-semibold">Tooltip</h1>
      <p class="text-muted-foreground mt-1">A popup that displays information related to an element when the element receives keyboard focus or the mouse hovers over it.</p>
    </div>
    <TooltipShowcase client:load />
  </div>
</Layout>
