---
import Layout from "@/layouts/main.astro"
import { AlertDialogShowcase } from "@/components/AlertDialogShowcase"
---

<Layout title="Alert Dialog — Interfero Design System">
  <div class="p-6 space-y-6">
    <div>
      <h1 class="text-2xl font-semibold">Alert Dialog</h1>
      <p class="text-muted-foreground mt-1">A modal dialog that interrupts the user with important content and expects a response.</p>
    </div>
    <AlertDialogShowcase client:load />
  </div>
</Layout>
