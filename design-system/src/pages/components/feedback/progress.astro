---
import Layout from "@/layouts/main.astro"
import { ProgressShowcase } from "@/components/ProgressShowcase"
---

<Layout title="Progress — Interfero Design System">
  <div class="p-6 space-y-6">
    <div>
      <h1 class="text-2xl font-semibold">Progress</h1>
      <p class="text-muted-foreground mt-1">Displays an indicator showing the completion progress of a task.</p>
    </div>
    <ProgressShowcase client:load />
  </div>
</Layout>
